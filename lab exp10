age = int(input("Enter Passenger Age: "))
fare = float(input("Enter Base Fare: "))
travel_class = input("Enter Class (Sleeper/AC): ")

if age < 5:
    final_fare = 0

elif age >= 60:
    final_fare = fare * 0.5

else:
    final_fare = fare

if travel_class.lower() == "ac":
    final_fare = final_fare + 200

print("Final Ticket Fare = Rs.", final_fare)
