total = 0

for i in range(1, 6):
    mark = int(input("Enter marks for Subject {}: ".format(i)))
    total += mark

average = total / 5

print("Total Marks =", total)
print("Average Marks =", average)

if average >= 90:
    grade = "A"
elif average >= 80:
    grade = "B"
elif average >= 70:
    grade = "C"
elif average >= 60:
    grade = "D"
else:
    grade = "F"

print("Grade =", grade)
